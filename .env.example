# Master .env example — choose one provider by copying one of the provider files
# or set these variables directly.

# Active provider: gmail | zoho | outlook
# Example: BULK_EMAIL_PROVIDER=gmail
BULK_EMAIL_PROVIDER=gmail

# Gmail (if using gmail)
BULK_GMAIL_USER=your@gmail.com
BULK_GMAIL_PASS=your-gmail-app-password

# Zoho (if using zoho)
ZOHO_USER=you@yourdomain.com
ZOHO_PASS=your-zoho-app-password

# Outlook (if using outlook/office365)
OUTLOOK_USER=you@yourdomain.com
OUTLOOK_PASS=your-outlook-app-password

# QR-email fallback (keeps QR email working)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password

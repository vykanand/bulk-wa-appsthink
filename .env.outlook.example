# Example .env for Outlook / Office365 bulk email provider
# Copy this file to `.env` or set the same variables in your environment

BULK_EMAIL_PROVIDER=outlook

# Outlook/Office365 SMTP credentials
OUTLOOK_USER=you@yourdomain.com
OUTLOOK_PASS=your-outlook-app-password

# Optional fallback QR email credentials
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your-outlook-app-password

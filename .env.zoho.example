# Example .env for Zoho Mail bulk email provider
# Copy this file to `.env` or set the same variables in your environment

BULK_EMAIL_PROVIDER=zoho

# Zoho SMTP credentials
ZOHO_USER=you@yourdomain.com
ZOHO_PASS=your-zoho-app-password

# Optional fallback QR email credentials
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your-zoho-app-password

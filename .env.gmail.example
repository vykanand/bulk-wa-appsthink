# Example .env for Gmail bulk email provider
# Copy this file to `.env` or set the same variables in your environment

BULK_EMAIL_PROVIDER=gmail

# Bulk Gmail credentials (used for bulk sends)
BULK_GMAIL_USER=your@gmail.com
BULK_GMAIL_PASS=your-gmail-app-password

# Fallback credentials used for QR emails (optional)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password
